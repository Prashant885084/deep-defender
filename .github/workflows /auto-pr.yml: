name: Auto PR every 30 min

on:
  schedule:
    - cron: "*/30 * * * *"
  workflow_dispatch:

permissions:
  contents: write
  pull-requests: write

jobs:
  create-pr:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Make your changes
        run: |
          date >> heartbeat.txt

      - name: Create Pull Request
        uses: peter-evans/create-pull-request@v7
        with:
          branch: auto/pr-every-30-min
          title: "Automated PR"
          body: "This PR was created automatically by GitHub Actions."
          commit-message: "chore: automated update"
